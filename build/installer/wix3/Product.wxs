<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">

  <Product
    Id="*"
    Name="ADE Insight"
    Language="1033"
    Version="0.2.0"
    Manufacturer="ADE"
    UpgradeCode="{C30A05CC-7163-406B-A36D-F2B8A2BB0A07}">

    <Package
      InstallerVersion="500"
      Compressed="yes"
      InstallScope="perMachine"
      Platform="x64" />

    <MajorUpgrade DowngradeErrorMessage="A newer version of ADE Insight is already installed." />
    <MediaTemplate />

    <Property Id="ARPPRODUCTICON" Value="AppIcon.ico" />
    <Icon Id="AppIcon.ico" SourceFile="src\ade_insight\gui\assets\adande_logo.ico" />

    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INSTALLFOLDER" Name="ADE Insight" />
      </Directory>

      <Directory Id="ProgramMenuFolder">
        <Directory Id="ProgramMenuDir" Name="ADE Insight">
          <Component Id="StartMenuShortcuts" Guid="*">
            <Shortcut
              Id="StartMenuShortcut"
              Name="ADE Insight"
              Description="ADE Insight"
              Target="[INSTALLFOLDER]ade-insight.exe"
              WorkingDirectory="INSTALLFOLDER" />
            <RemoveFolder Id="RemoveProgramMenuDir" On="uninstall" />
	    <RegistryValue
	      Icon="AppIcon.ico"
	      IconIndex="0"
              Root="HKLM"
              Key="Software\ADE\ADEInsight"
              Name="Installed"
              Type="integer"
              Value="1"
              KeyPath="yes" />
          </Component>
        </Directory>
      </Directory>
    </Directory>

    <Feature Id="MainFeature" Title="ADE Insight" Level="1">
      <ComponentGroupRef Id="ADEInsightFiles" />
      <ComponentRef Id="StartMenuShortcuts" />
    </Feature>

  </Product>
</Wix>
